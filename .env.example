# ===== Anthropic =====
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Model — defaults to claude-opus-4-7 if unset
ANTHROPIC_MODEL=claude-opus-4-7

# ===== Server =====
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# ===== Auth / session =====
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=
# Set to true in production (HTTPS only); false for local http
SESSION_HTTPS_ONLY=false
# SQLite path (default: ./agentforge.db). Use a Railway Volume for persistence in prod.
DATABASE_URL=sqlite:///./agentforge.db

# ===== Bootstrap default user (optional) =====
# If all three are set AND the users table is empty, a single user is created on startup.
# Useful for Railway's ephemeral filesystem; not needed locally if you use the admin CLI.
DEFAULT_USER_USERNAME=
DEFAULT_USER_EMAIL=
DEFAULT_USER_PASSWORD=

# ===== Email (Phase 3 — password reset) =====
# Sign up at https://resend.com (free tier: 3,000/month, 100/day)
RESEND_API_KEY=
# A "from" email at a verified domain in Resend, or onboarding@resend.dev for testing
RESEND_FROM=
# Public base URL used in password-reset email links
APP_BASE_URL=http://127.0.0.1:8000
