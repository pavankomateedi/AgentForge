# ===== Anthropic =====
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Model — defaults to claude-opus-4-7 if unset
ANTHROPIC_MODEL=claude-opus-4-7

# ===== Server =====
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# ===== Auth / session =====
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=
# Set to true in production (HTTPS only); false for local http
SESSION_HTTPS_ONLY=false
# SQLite path (default: ./agentforge.db). Use a Railway Volume for persistence in prod.
DATABASE_URL=sqlite:///./agentforge.db

# ===== Bootstrap default user (optional) =====
# If all three are set AND the users table is empty, a single user is created on startup.
# Useful for Railway's ephemeral filesystem; not needed locally if you use the admin CLI.
DEFAULT_USER_USERNAME=
DEFAULT_USER_EMAIL=
DEFAULT_USER_PASSWORD=

# ===== Bootstrap extra users (optional, JSON list) =====
# Survives ephemeral filesystems — every cold start re-seeds whatever
# this declares. Idempotent: existing users are left alone, assignments
# are deduped. Optional `totp_secret` (base32) pre-enrolls MFA so a
# known TOTP code can be generated externally — only safe for synthetic
# data, see HIPAA_COMPLIANCE.md.
#
# Example (single line — env vars must be one line):
# EXTRA_USERS_JSON=[{"username":"grader.demo","email":"grader@example.com","password":"GraderDemo!2026","role":"physician","patients":["demo-001","demo-002","demo-003","demo-004","demo-005"],"totp_secret":"6AV66JNIZTTPEBNBIUQWE2M7GVPNKDBD"},{"username":"nurse.adams","email":"nurse@example.com","password":"NurseDemo!2026","role":"nurse","patients":["demo-001"],"totp_secret":"LMLIHJIU6JGPW2KCFYDVLGETQX54QUFG"}]
EXTRA_USERS_JSON=

# ===== Email (Phase 3 — password reset) =====
# Sign up at https://resend.com (free tier: 3,000/month, 100/day)
RESEND_API_KEY=
# A "from" email at a verified domain in Resend, or onboarding@resend.dev for testing
RESEND_FROM=
# Public base URL used in password-reset email links
APP_BASE_URL=http://127.0.0.1:8000

# ===== Observability (Langfuse) =====
# Sign up at https://us.cloud.langfuse.com — free tier is generous.
# Project Settings → API Keys → create a new key pair.
# Leave blank to disable tracing entirely; the app no-ops cleanly.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# US region default. EU users: https://cloud.langfuse.com
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ===== Cost guard =====
# Hard daily per-user token cap (input+output across both LLM calls).
# Set to 0 to disable. Default 200000 ~= ~25-50 turns at typical usage.
DAILY_TOKEN_BUDGET=200000
