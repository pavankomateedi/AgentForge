# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.egg

# Node / Vite (UI is in ui/, build output goes to agent/static which IS committed)
node_modules/
ui/dist/
ui/.vite/
.eslintcache

# Virtual envs
.venv/
venv/
env/

# Secrets / local config
.env
.env.local

# SQLite (auth + audit log) — local-only; ephemeral on Railway by default
*.db
*.db-journal
*.db-wal
*.db-shm

# Editors / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Terraform — never commit local state, plan output, or filled-in tfvars.
# The blueprint files (*.tf) and the example tfvars ARE committed.
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/*.tfvars.example
terraform/*.tfplan
terraform/crash.log
terraform/crash.*.log
