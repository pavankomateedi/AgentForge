# OpenEMR base URL (no trailing slash). For local Docker default: http://localhost:8080
VITE_OPENEMR_BASE_URL=http://localhost:8080

# FHIR base. OpenEMR exposes FHIR R4 at /apis/default/fhir
VITE_OPENEMR_FHIR_BASE=http://localhost:8080/apis/default/fhir

# OAuth2 endpoints. OpenEMR site is "default" by default.
VITE_OAUTH_AUTHORIZE_URL=http://localhost:8080/oauth2/default/authorize
VITE_OAUTH_TOKEN_URL=http://localhost:8080/oauth2/default/token

# Client credentials from OpenEMR API Clients admin page.
VITE_OAUTH_CLIENT_ID=

# Redirect URI registered in OpenEMR. Must match exactly. The /dashboard prefix
# matches the BrowserRouter basename and the production FastAPI static mount.
VITE_OAUTH_REDIRECT_URI=http://localhost:5174/dashboard/oauth/callback

# Scopes. Public client + patient-level FHIR read.
VITE_OAUTH_SCOPES=openid offline_access api:fhir patient/Patient.read patient/AllergyIntolerance.read patient/Condition.read patient/MedicationRequest.read patient/MedicationStatement.read patient/CareTeam.read patient/Practitioner.read patient/PractitionerRole.read patient/Observation.read
